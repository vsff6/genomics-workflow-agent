{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProvenanceRecord",
  "description": "Per-step provenance captured by runner.py for each executed command.",
  "type": "object",
  "required": ["label", "command", "dry_run", "started_at", "executed"],
  "properties": {
    "label": {"type": "string", "description": "Step name"},
    "command": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Full command as a list"
    },
    "command_str": {"type": "string", "description": "Command as a single string"},
    "cwd": {"type": "string", "description": "Working directory at execution time"},
    "dry_run": {"type": "boolean"},
    "started_at": {"type": "string", "format": "date-time"},
    "ended_at": {"type": ["string", "null"], "format": "date-time"},
    "return_code": {"type": ["integer", "null"]},
    "stdout_snippet": {"type": ["string", "null"]},
    "stderr_snippet": {"type": ["string", "null"]},
    "runtime_s": {"type": ["number", "null"]},
    "executed": {"type": "boolean"},
    "status": {
      "type": "string",
      "enum": ["planned", "succeeded", "failed", "skipped", "error"]
    },
    "output_validation": {
      "type": "object",
      "properties": {
        "all_present": {"type": "boolean"},
        "missing": {"type": "array", "items": {"type": "string"}},
        "found": {"type": "array", "items": {"type": "string"}}
      }
    },
    "error": {"type": ["string", "null"]}
  }
}
